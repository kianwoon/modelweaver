{
  "name": "@kianwoon/modelweaver",
  "version": "0.3.46",
  "description": "Multi-provider model orchestration proxy for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "modelweaver": "dist/index.js",
    "mw": "dist/index.js"
  },
  "scripts": {
